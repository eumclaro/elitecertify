generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  name              String
  email             String          @unique
  passwordHash      String          @map("password_hash")
  role              Role            @default(STUDENT)
  active            Boolean         @default(true)
  sessionToken      String?         @map("session_token")
  lastLoginIp       String?         @map("last_login_ip")
  lastLoginDevice   String?         @map("last_login_device")
  lastLoginAt       DateTime?       @map("last_login_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  resetToken        String?         @map("reset_token")
  resetTokenExpires DateTime?       @map("reset_token_expires")
  avatarUrl         String?         @map("avatar_url")
  inviteToken       String?         @unique @map("invite_token")
  inviteExpires     DateTime?       @map("invite_expires")
  auditEvents       AuditEvent[]
  npsSurveys        NpsSurvey[]
  student           Student?
  systemSettings    SystemSetting[]

  @@map("users")
}

model Student {
  id             String         @id @default(uuid())
  userId         String         @unique @map("user_id")
  cpf            String?        @unique
  phone          String?
  enrollmentDate DateTime       @default(now()) @map("enrollment_date")
  status         String         @default("ACTIVE")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  lastName       String?        @map("last_name")
  certificates   Certificate[]
  classes        ClassStudent[]
  cooldowns      Cooldown[]
  examAttempts   ExamAttempt[]
  examReleases   ExamRelease[]
  npsInvites     NpsInvite[]
  npsResponses   NpsResponse[]
  eventInterests EventInterest[]
  eventReferrals EventReferral[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("students")
}

model Class {
  id           String         @id @default(uuid())
  name         String
  description  String?
  startDate    DateTime?      @map("start_date")
  endDate      DateTime?      @map("end_date")
  status       String         @default("ACTIVE")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  students     ClassStudent[]
  examReleases ExamRelease[]
  npsSurveys   NpsSurvey[]

  @@map("classes")
}

model ClassStudent {
  id        String   @id @default(uuid())
  classId   String   @map("class_id")
  studentId String   @map("student_id")
  joinedAt  DateTime @default(now()) @map("joined_at")
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("class_students")
}

model Exam {
  id              String        @id @default(uuid())
  title           String
  description     String?
  questionCount   Int           @default(10) @map("question_count")
  durationMinutes Int           @default(60) @map("duration_minutes")
  passingScore    Float         @default(70) @map("passing_score")
  maxAttempts     Int           @default(0) @map("max_attempts")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  cooldownDays    Int           @default(0) @map("cooldown_days")
  questionOrder   QuestionOrder @default(FIXED) @map("question_order")
  status          ExamStatus    @default(DRAFT)
  certificateTemplateId String? @map("certificate_template_id")
  certificateTemplate   CertificateTemplate? @relation(fields: [certificateTemplateId], references: [id])
  certificates    Certificate[]
  cooldowns       Cooldown[]
  attempts        ExamAttempt[]
  releases        ExamRelease[]
  questions       Question[]

  @@map("exams")
}

model Question {
  id           String        @id @default(uuid())
  examId       String        @map("exam_id")
  text         String
  order        Int           @default(0)
  type         QuestionType  @default(SINGLE_CHOICE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  alternatives Alternative[]
  answers      Answer[]
  exam         Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model Alternative {
  id         String   @id @default(uuid())
  questionId String   @map("question_id")
  text       String
  isCorrect  Boolean  @default(false) @map("is_correct")
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    Answer[]

  @@map("alternatives")
}

model ExamRelease {
  id         String   @id @default(uuid())
  examId     String   @map("exam_id")
  classId    String?  @map("class_id")
  releasedBy String   @map("released_by")
  releasedAt DateTime @default(now()) @map("released_at")
  studentId  String?  @map("student_id")
  class      Class?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student    Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@map("exam_releases")
}

model ExamAttempt {
  id              String                 @id @default(uuid())
  examId          String                 @map("exam_id")
  studentId       String                 @map("student_id")
  startedAt       DateTime               @default(now()) @map("started_at")
  finishedAt      DateTime?              @map("finished_at")
  score           Float?
  ip              String?
  device          String?
  createdAt       DateTime               @default(now()) @map("created_at")
  executionStatus AttemptExecutionStatus @default(IN_PROGRESS) @map("execution_status")
  resultStatus    AttemptResultStatus    @default(PENDING) @map("result_status")
  correctAnswers  Int?                   @map("correct_answers")
  totalQuestions  Int?                   @map("total_questions")
  answers         Answer[]
  certificate     Certificate?
  exam            Exam                   @relation(fields: [examId], references: [id], onDelete: Cascade)
  student         Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("exam_attempts")
}

model Answer {
  id            String       @id @default(uuid())
  attemptId     String       @map("attempt_id")
  questionId    String       @map("question_id")
  alternativeId String?      @map("alternative_id")
  isCorrect     Boolean      @default(false) @map("is_correct")
  createdAt     DateTime     @default(now()) @map("created_at")
  alternative   Alternative? @relation(fields: [alternativeId], references: [id])
  attempt       ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}

model Cooldown {
  id        String         @id @default(uuid())
  studentId String         @map("student_id")
  examId    String         @map("exam_id")
  startedAt DateTime       @default(now()) @map("started_at")
  endsAt    DateTime       @map("ends_at")
  status    CooldownStatus @default(ACTIVE)
  exam      Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("cooldowns")
}

model Certificate {
  id          String       @id @default(uuid())
  studentId   String       @map("student_id")
  examId      String       @map("exam_id")
  attemptId   String       @unique @map("attempt_id")
  code        String       @unique
  issuedAt    DateTime     @default(now()) @map("issued_at")
  webhookSent Boolean      @default(false) @map("webhook_sent")
  attempt     ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  exam        Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  webhookLogs WebhookLog[]

  @@map("certificates")
}

model WebhookLog {
  id            String      @id @default(uuid())
  certificateId String      @map("certificate_id")
  url           String
  payload       String
  statusCode    Int?        @map("status_code")
  response      String?
  sentAt        DateTime    @default(now()) @map("sent_at")
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

model NpsSurvey {
  id        String        @id @default(uuid())
  title     String
  classId   String?       @map("class_id")
  createdBy String        @map("created_by")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  status    NpsStatus     @default(DRAFT)
  invites   NpsInvite[]
  questions NpsQuestion[]
  responses NpsResponse[]
  class     Class?        @relation(fields: [classId], references: [id])
  creator   User          @relation(fields: [createdBy], references: [id])

  @@map("nps_surveys")
}

model NpsQuestion {
  id              String              @id @default(uuid())
  surveyId        String              @map("survey_id")
  text            String
  order           Int                 @default(0)
  createdAt       DateTime            @default(now()) @map("created_at")
  type            NpsQuestionType     @default(SCORE)
  options         String?             @map("options")
  survey          NpsSurvey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responseDetails NpsResponseDetail[]

  @@map("nps_questions")
}

model NpsInvite {
  id          String          @id @default(uuid())
  surveyId    String          @map("survey_id")
  studentId   String          @map("student_id")
  token       String          @unique @default(uuid())
  respondedAt DateTime?       @map("responded_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  status      NpsInviteStatus @default(PENDING)
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  survey      NpsSurvey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  response    NpsResponse?

  @@map("nps_invites")
}

model NpsResponse {
  id        String              @id @default(uuid())
  surveyId  String              @map("survey_id")
  studentId String              @map("student_id")
  inviteId  String?             @unique @map("invite_id")
  createdAt DateTime            @default(now()) @map("created_at")
  details   NpsResponseDetail[]
  invite    NpsInvite?          @relation(fields: [inviteId], references: [id])
  student   Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  survey    NpsSurvey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("nps_responses")
}

model NpsResponseDetail {
  id         String      @id @default(uuid())
  responseId String      @map("response_id")
  questionId String      @map("question_id")
  score      Int?
  text       String?
  question   NpsQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response   NpsResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@map("nps_response_details")
}

model AuditEvent {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  ip        String?
  device    String?
  metadata  String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_events")
}

model EmailLog {
  id            String    @id @default(uuid())
  eventKey      String    @map("event_key")
  templateUsed  String    @map("template_used")
  recipient     String
  subject       String?
  payloadJson   String?   @map("payload_json")
  provider      String
  mandrillMsgId String?   @unique @map("mandrill_msg_id")
  status        String    @default("PENDING")
  errorMessage  String?   @map("error_message")
  sentAt        DateTime? @map("sent_at")
  openedAt      DateTime? @map("opened_at")
  clickedAt     DateTime? @map("clicked_at")
  bouncedAt     DateTime? @map("bounced_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  dispatchId    String?   @map("dispatch_id")
  dispatch      Dispatch? @relation(fields: [dispatchId], references: [id])

  @@index([mandrillMsgId])
  @@index([recipient])
  @@index([eventKey])
  @@map("email_logs")
}

model EmailTemplate {
  id               String              @id @default(uuid())
  name             String
  slug             String              @unique
  provider         String              @default("MANDRILL")
  status           String              @default("active")
  allowedMergeVars String?             @map("allowed_merge_vars")
  lastSyncedAt     DateTime?           @map("last_synced_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  htmlContent      String?             @map("html_content")
  bindings         EmailEventBinding[]

  @@map("email_templates")
}

model InternalTemplate {
  id          String              @id @default(uuid())
  name        String
  description String?
  htmlContent String?             @map("html_content")
  mergeVars   Json?               @map("merge_vars")
  status      String              @default("DRAFT")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  bindings    EmailEventBinding[]

  @@map("internal_templates")
}

model EmailEventBinding {
  id                 String            @id @default(uuid())
  eventKey           String            @unique
  templateId         String?           @map("template_id")
  isActive           Boolean           @default(true) @map("is_active")
  fallbackTemplateId String?           @map("fallback_template_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  internalTemplateId String?           @map("internal_template_id")
  internalTemplate   InternalTemplate? @relation(fields: [internalTemplateId], references: [id])
  template           EmailTemplate?    @relation(fields: [templateId], references: [id])

  @@map("email_event_bindings")
}

model Dispatch {
  id             String     @id @default(uuid())
  templateSlug   String     @map("template_slug")
  recipientGroup String?    @map("recipient_group")
  totalSent      Int        @default(0) @map("total_sent")
  totalFailed    Int        @default(0) @map("total_failed")
  failedEmails   Json?      @map("failed_emails")
  createdAt      DateTime   @default(now()) @map("created_at")
  logs           EmailLog[]

  @@map("dispatches")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User?    @relation(fields: [updatedBy], references: [id])

  @@map("system_settings")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  VIEWER
  STUDENT
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  ESSAY
}

enum QuestionOrder {
  FIXED
  RANDOM
}

enum CooldownStatus {
  ACTIVE
  CLEARED
  EXPIRED
}

enum AttemptExecutionStatus {
  AVAILABLE
  IN_PROGRESS
  FINISHED
  ABANDONED
  EXPIRED
  COOLDOWN_BLOCKED
}

enum AttemptResultStatus {
  PENDING
  PASSED
  FAILED
  FAILED_TIMEOUT
  FAILED_ABANDONMENT
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NpsStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum NpsInviteStatus {
  PENDING
  RESPONDED
  EXPIRED
}

enum NpsQuestionType {
  SCORE
  TEXT
  MULTIPLE_CHOICE
  RATING_5
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

model Event {
  id               String          @id @default(uuid())
  title            String
  shortDescription String          @map("short_description")
  longDescription  String          @map("long_description")
  date             DateTime
  location         String
  isOnline         Boolean         @default(false) @map("is_online")
  coverImageUrl    String          @map("cover_image_url")
  totalSpots       Int?            @map("total_spots")
  price            Float?
  status           EventStatus     @default(DRAFT)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  interests        EventInterest[]
  referrals        EventReferral[]

  @@map("events")
}

model EventInterest {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  studentId String   @map("student_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
  @@map("event_interests")
}

model EventReferral {
  id            String   @id @default(uuid())
  eventId       String   @map("event_id")
  referrerId    String   @map("referrer_id")
  referredName  String   @map("referred_name")
  referredEmail String   @map("referred_email")
  referredPhone String?  @map("referred_phone")
  converted     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  referrer      Student  @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@map("event_referrals")
}

model CertificateTemplate {
  id              String   @id @default(uuid())
  name            String
  fileName        String   @map("file_name")
  nameTop         Float    @default(53.1) @map("name_top")
  nameLeft        Float    @default(14.2) @map("name_left")
  codeTop         Float    @default(72.1) @map("code_top")
  codeLeft        Float    @default(59.1) @map("code_left")
  dateBottom      Float    @default(12.0) @map("date_bottom")
  dateLeft        Float    @default(16.2) @map("date_left")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  exams           Exam[]

  @@map("certificate_templates")
}
